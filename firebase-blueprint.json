{
  "entities": {
    "Config": {
      "title": "Config",
      "description": "Application configuration settings",
      "type": "object",
      "properties": {
        "sheetUrl": { "type": "string" },
        "phoneColumn": { "type": "string" },
        "statusColumn": { "type": "string" },
        "adminPassword": { "type": "string" }
      },
      "required": ["sheetUrl", "adminPassword"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "Subscriber information",
      "type": "object",
      "properties": {
        "last9Digits": { "type": "string" },
        "fullPhoneNumber": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["last9Digits", "status"]
    }
  },
  "firestore": {
    "settings/main": {
      "schema": "Config",
      "description": "Global application settings"
    },
    "subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Subscriber records"
    }
  }
}
